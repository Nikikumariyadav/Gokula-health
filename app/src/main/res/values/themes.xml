<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GokulaHealth" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/blue_info</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/green_primary</item>
    </style>

    <style name="Theme.GokulaHealth.Splash" parent="Theme.GokulaHealth">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <style name="Theme.GokulaHealth.ActionBar" parent="Theme.MaterialComponents.DayNight">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/green_primary</item>
    </style>
</resources>
